{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Verify Evidence Item",
  "type": "object",
  "required": ["evidence_id", "claim_id", "type", "source", "locator", "method", "captured_at_utc", "result_summary", "limitations"],
  "properties": {
    "evidence_id": {"type": "string", "minLength": 1},
    "claim_id": {"type": "string", "minLength": 1},
    "type": {
      "type": "string",
      "enum": ["command", "file_excerpt", "diff", "test", "build", "artifact", "screenshot", "connector", "web_source", "calculation", "user_supplied", "manual_step"]
    },
    "source": {"type": "string", "minLength": 1},
    "locator": {"type": "string"},
    "method": {"type": "string", "minLength": 1},
    "captured_at_utc": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "result_summary": {"type": "string", "minLength": 1},
    "raw_output_sha256": {"type": ["string", "null"], "pattern": "^[a-fA-F0-9]{64}$"},
    "stable_pointer": {"type": ["string", "null"]},
    "limitations": {"type": "string"},
    "command": {
      "type": "object",
      "required": ["cwd", "exact_command", "argv", "exit_code", "stdout_sha256", "stderr_sha256", "duration_seconds"],
      "properties": {
        "cwd": {"type": "string"},
        "exact_command": {"type": "string"},
        "argv": {"type": "array", "items": {"type": "string"}},
        "exit_code": {"type": ["integer", "null"]},
        "stdout_sha256": {"type": ["string", "null"], "pattern": "^[a-fA-F0-9]{64}$"},
        "stderr_sha256": {"type": ["string", "null"], "pattern": "^[a-fA-F0-9]{64}$"},
        "duration_seconds": {"type": ["number", "null"]}
      }
    },
    "stdout": {"type": "string"},
    "stderr": {"type": "string"},
    "omitted_raw_output": {"type": "boolean"}
  },
  "allOf": [
    {
      "if": {"properties": {"type": {"const": "command"}}, "required": ["type"]},
      "then": {"required": ["command"]}
    },
    {
      "anyOf": [
        {
          "required": ["raw_output_sha256"],
          "properties": {"raw_output_sha256": {"type": "string", "pattern": "^[a-fA-F0-9]{64}$"}}
        },
        {
          "required": ["stable_pointer"],
          "properties": {"stable_pointer": {"type": "string", "minLength": 1}}
        }
      ]
    }
  ]
}
